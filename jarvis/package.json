{
  "name": "jarvis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fetch-wake-models": "node scripts/fetch-wake-models.mjs",
    "sync:cargo-win-env": "node scripts/sync-cargo-win-env.mjs",
    "prebuild": "node scripts/fetch-wake-models.mjs",
    "postinstall": "node scripts/sync-cargo-win-env.mjs",
    "precargo": "node scripts/sync-cargo-win-env.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "tauri:dev": "node scripts/whisper-gpu/run-tauri.mjs dev",
    "tauri:dev:cpu": "node scripts/whisper-gpu/run-tauri-cpu.mjs dev",
    "tauri:build": "node scripts/whisper-gpu/run-tauri.mjs build",
    "tauri:build:cpu": "node scripts/whisper-gpu/run-tauri-cpu.mjs build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:wake": "vitest run scripts/fetch-wake-models.config.test.mjs && cargo test --manifest-path src-tauri/Cargo.toml --features oww audio::wake::oww",
    "cargo": "node scripts/cargo-win-env.mjs",
    "test:cargo-whisper-vulkan": "node scripts/cargo-win-env.mjs check --manifest-path src-tauri/Cargo.toml --no-default-features --features whisper-vulkan,oww",
    "test:cargo-whisper-cuda": "node scripts/cargo-win-env.mjs check --manifest-path src-tauri/Cargo.toml --no-default-features --features whisper-cuda,oww",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "tauri": "node scripts/whisper-gpu/run-tauri.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/work-sans": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "framer-motion": "^12.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
