{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jarvis",
  "version": "0.1.0",
  "identifier": "com.jarvis.app",
  "build": {
    "beforeDevCommand": "npm run fetch-wake-models && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "hud",
        "title": "JARVIS",
        "width": 480,
        "height": 172,
        "minWidth": 480,
        "maxWidth": 480,
        "minHeight": 120,
        "resizable": true,
        "visible": false,
        "theme": "Dark",
        "backgroundColor": "#000000",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "editor",
        "title": "VLI",
        "url": "editor.html",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#000000",
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/ggml-tiny.en.bin",
      "resources/porcupine/libpv_porcupine.dll",
      "resources/porcupine/porcupine_params.pv",
      "resources/porcupine/porcupine_windows.ppn",
      "resources/oww/melspectrogram.onnx",
      "resources/oww/embedding_model.onnx",
      "resources/oww/hey_jarvis_v0.1.onnx"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
